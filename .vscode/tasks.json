{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run MCP Server HTTP",
			"type": "shell",
			"command": ".venv\\Scripts\\python.exe",
			"args": [
				"-c",
				"from fastmcp.cli import app; app()",
				"run",
				"main.py:mcp",
				"--transport",
				"http",
				"--port",
				"8000"
			],
			"isBackground": true
		}
	]
}